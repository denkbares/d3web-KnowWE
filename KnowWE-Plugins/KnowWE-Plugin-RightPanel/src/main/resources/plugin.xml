<!DOCTYPE plugin PUBLIC "-//JPF//Java Plug-in Manifest 1.0"
	"http://jpf.sourceforge.net/plugin_1_0.dtd">
<plugin id="KnowWE-Plugin-RightPanel" version="1.0">

	<requires>
		<import plugin-id="KnowWEExtensionPoints" />
	</requires>

	<runtime>
		<library id="de.d3web" path="." type="code">
			<export prefix="*" />
		</library>
		<library id="webapp" path="webapp/" type="resources">
			<export prefix="*" />
		</library>
	</runtime>

	<extension plugin-id="KnowWEExtensionPoints" point-id="PageAppendHandler" id="RightPanelAppendHandler">
		<parameter id="class" value="de.knowwe.rightpanel.RightPanelAppendHandler" />
		<parameter id="name" value="RightPanelAppendHandler" />
		<parameter id="description" value="Scaffolds the right panel DOM (tab strip + tab bodies) inline during page render." />
		<parameter id="version" value="1.0" />
		<parameter id="priority" value="5" />
	</extension>

	<extension plugin-id="KnowWEExtensionPoints" point-id="RightPanelTab" id="custom">
		<parameter id="class" value="de.knowwe.rightpanel.custom.CustomContentTabProvider" />
		<parameter id="name" value="CustomContentTabProvider" />
		<parameter id="description" value="Built-in 'Custom' tab showing the wiki-editable RightPanel article. Carries the core right panel JS/CSS." />
		<parameter id="version" value="1.0" />
		<parameter id="priority" value="5" />
		<parameter id="script" value="KnowWE-Plugin-RightPanel.js" />
		<parameter id="css" value="KnowWE-Plugin-RightPanel.css" />
	</extension>

</plugin>