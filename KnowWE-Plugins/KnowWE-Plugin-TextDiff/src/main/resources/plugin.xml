<?xml version="1.0" ?>
<!DOCTYPE plugin PUBLIC "-//JPF//Java Plug-in Manifest 1.0"
	"http://jpf.sourceforge.net/plugin_1_0.dtd">
<plugin id="KnowWE-Plugin-TextDiff" version="1.0-SNAPSHOT">

	<requires>
		<import plugin-id="KnowWEExtensionPoints" />
	</requires>

	<runtime>
		<library id="de.knowwe" path="." type="code">
			<export prefix="*" />
		</library>
		<library id="webapp" path="webapp/" type="resources">
			<export prefix="*" />
		</library>
	</runtime>

	<extension plugin-id="KnowWEExtensionPoints" point-id="Action" id="TextDiffAction">
		<parameter id="class" value="com.denkbares.knowwe.textdiff.TextDiffAction" />
		<parameter id="name" value="TextDiffAction" />
		<parameter id="description" value="Computes a diff between two raw texts and returns the rendered shadow-root HTML." />
		<parameter id="version" value="1.0" />
		<parameter id="priority" value="5" />
		<parameter id="script" value="KnowWE-Plugin-TextDiff.js" />
		<parameter id="css" value="KnowWE-Plugin-TextDiff.css" />
	</extension>

</plugin>
